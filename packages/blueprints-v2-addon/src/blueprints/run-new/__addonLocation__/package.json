{
  "name": "<%= options.addon.name %>",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "keywords": [
    "ember-addon"
  ],
  "repository": "",
  "exports": {
    ".": {
      "types": "./declarations/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./declarations/*.d.ts",
      "default": "./dist/*.js"
    },
    "./addon-main.js": "./addon-main.cjs"
  },
  "typesVersions": {
    "*": {
      "*": [
        "declarations/*"
      ]
    }
  },
  "files": [
    "addon-main.cjs",
    "declarations",
    "dist",
    "public"
  ],
  "scripts": {
    "addon": "blueprints-v2-addon --test-app-location \"<%= options.addon.locationInverse %>/<%= options.testApp.location %>\"",
    "build": "rollup --config",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \"**/*.css\" --allow-empty-input --cache",
    "lint:css:fix": "stylelint \"**/*.css\" --allow-empty-input --fix",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "prelint:types": "type-css-modules --src src",
    "lint:types": "ember-tsc --noEmit",
    "prepack": "rollup --config",
    "start": "rollup --config --watch",
    "test": "echo \"A v2 addon does not have tests, run tests in <%= options.testApp.name %>\""
  },
  "dependencies": {
    "@embroider/addon-shim": "^1.10.3",
    "decorator-transforms": "^2.4.0",
    "embroider-css-modules": "^4.1.0",
    "ember-modifier": "^4.3.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-typescript": "^8.0.1",
    "@babel/runtime": "^8.0.0",
    "@ember/test-helpers": "^5.4.3",
    "@embroider/addon-dev": "^8.3.1",
    "@glimmer/component": "^2.1.1",
    "@glimmer/tracking": "^1.1.2",
    "@glint/ember-tsc": "^1.8.11",
    "@glint/template": "^1.7.8",
    "@glint/tsserver-plugin": "^2.5.17",
    "@rollup/plugin-babel": "^7.1.0",
    "@shared-configs/eslint-config-ember": "workspace:*",
    "@shared-configs/prettier": "workspace:*",
    "@shared-configs/stylelint": "workspace:*",
    "@shared-configs/typescript": "workspace:*",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "blueprints-v2-addon": "workspace:*",
    "concurrently": "^10.0.3",
    "ember-source": "~7.1.0",
    "eslint": "^10.6.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "qunit-dom": "^3.5.1",
    "rollup": "^4.62.2",
    "rollup-plugin-postcss": "^4.0.2",
    "stylelint": "^17.14.0",
    "type-css-modules": "^3.2.8",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@ember/test-helpers": "^5.4.3",
    "qunit-dom": "^3.5.1"
  },
  "peerDependenciesMeta": {
    "@ember/test-helpers": {
      "optional": true
    },
    "qunit-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": "22.* || >= 24"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "app-js": {},
    "main": "addon-main.cjs",
    "public-assets": {},
    "type": "addon",
    "version": 2
  }
}
